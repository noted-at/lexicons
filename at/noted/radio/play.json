{
    "$type": "com.atproto.lexicon.schema",
    "id": "at.noted.radio.play",
    "description": "A play of a track on a radio show",
    "lexicon": 1,
    "defs": {
        "main": {
            "type": "record",
            "key": "any",
            "description": "Record representing a single played item",
            "record": {
                "type": "object",
                "required": [
                    "airdate",
                    "id",
                    "playType",
                    "createdAt"
                ],
                "properties": {
                    "airdate": {
                        "type": "string",
                        "format": "datetime"
                    },
                    "album": {
                        "type": "string",
                        "maxLength": 500
                    },
                    "artist": {
                        "type": "string",
                        "maxLength": 500
                    },
                    "comment": {
                        "type": "string",
                        "maxLength": 5000
                    },
                    "id": {
                        "type": "integer"
                    },
                    "imageUri": {
                        "type": "string",
                        "format": "uri"
                    },
                    "playType": {
                        "type": "string",
                        "maxLength": 20,
                        "knownValues": [
                            "airbreak",
                            "trackplay"
                        ]
                    },
                    "show": {
                        "type": "string",
                        "format": "at-uri"
                    },
                    "song": {
                        "type": "string",
                        "maxLength": 500
                    },
                    "thumbnailUri": {
                        "type": "string",
                        "format": "uri"
                    },
                    "createdAt": {
                        "type": "string",
                        "format": "datetime"
                    }
                }
            }
        }
    }
}